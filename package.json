  "license": "MIT",
  "copyright": "Copyright (c) 2025 光波. All rights reserved.",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "dev": "vite",
    "server:dev": "npm --prefix server run dev",
    "server:start": "npm --prefix server run start",
    "check:text-integrity": "node ./scripts/check-text-integrity.mjs",
    "check:create-project-flow": "node ./scripts/check-create-project-flow.mjs",
    "fix:text-encoding": "node ./scripts/normalize-text-encoding.mjs",
    "build": "node ./scripts/check-text-integrity.mjs && vite build",
    "preview": "vite preview",
    "test": "node ./scripts/check-text-integrity.mjs && vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@google/genai": "^1.30.0",
    "@xyflow/react": "^12.10.1",
    "cos-js-sdk-v5": "^1.10.1",
    "immer": "^11.1.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.555.0",
    "playwright": "^1.58.2",
    "playwright-core": "^1.58.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "swr": "^2.3.8",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@sentry/react": "^10.32.1",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "docx": "^9.5.1",
    "esbuild": "^0.27.3",
    "jsdom": "^28.0.0",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.0.18"
  }
}
